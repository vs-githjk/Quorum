# ── LLM ──────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
HERMES_HOST=http://localhost:11434
HERMES_MODEL=hermes3

# ── Agent behaviour ───────────────────────────────────────────────────────────
QUORUM_MODE=on_demand       # on_demand | active
QUORUM_PROACTIVE=false      # true = offer before acting (active mode only)
LOG_LEVEL=INFO

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=               # Personal access token (fine-grained or classic)
GITHUB_OWNER=               # Org or user name e.g. acme-corp
GITHUB_REPO=                # Repo name e.g. backend

# ── Notion ────────────────────────────────────────────────────────────────────
NOTION_TOKEN=               # Integration secret (starts with ntn_ or secret_)

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=            # xoxb- token (needs search:read scope)

# ── Asana ─────────────────────────────────────────────────────────────────────
ASANA_TOKEN=                # Personal access token from app.asana.com/my-apps
ASANA_WORKSPACE_GID=        # Workspace GID (GET /workspaces to find it)
